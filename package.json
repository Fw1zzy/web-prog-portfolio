{
  "name": "portfolio-monorepo",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": "20"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "install:all": "npm i --workspaces && cd frontend && npm i && cd ../backend && npm i"
  }
}
